# Pass The Bug — Environment Variables
# Copy this to .env and fill in your actual credentials

# Turso Database (https://turso.tech)
# Create a database at app.turso.tech, then copy the URL and token
TURSO_DATABASE_URL=libsql://database-name.turso.io
TURSO_AUTH_TOKEN=turso_auth_token_here

# Google Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=gemini_api_key_here

# Superuser password — change this before production use
SUPERUSER_PASSWORD=IIE@279
